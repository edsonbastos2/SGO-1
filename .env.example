# ============================================================
# SGO - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Prisma (Supabase Pooler para conexões serverless)
DATABASE_URL=postgresql://postgres.SEU_PROJECT_ID:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.SEU_PROJECT_ID:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# Auth (JWT)
JWT_SECRET=gere_uma_chave_secreta_de_pelo_menos_32_caracteres
JWT_EXPIRES_IN=8h

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Upload de arquivos (Supabase Storage)
SUPABASE_STORAGE_BUCKET=sgo-evidencias
